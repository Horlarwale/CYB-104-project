b<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tvInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:gravity="end"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="123 + 456" />

    <TextView
        android:id="@+id/tvResult"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:gravity="end"
        android:textColor="#888888"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvInput"
        tools:text="579" />

    <Button
        android:id="@+id/btnMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:layout_marginTop="300dp"
        android:layout_marginEnd="120dp"
        android:text="Scientific"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvResult" />

    <GridLayout
        android:id="@+id/scientificPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:visibility="gone"
        android:padding="4dp"
        app:layout_constraintBottom_toTopOf="@+id/basicPanel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <Button android:text="sin" style="@style/CalcButton.Scientific" />
        <Button android:text="cos" style="@style/CalcButton.Scientific" />
        <Button android:text="tan" style="@style/CalcButton.Scientific" />
        <Button android:text="log" style="@style/CalcButton.Scientific" />
        <Button android:text="ln" style="@style/CalcButton.Scientific" />
        <Button android:text="√" style="@style/CalcButton.Scientific" />
        <Button android:text="π" style="@style/CalcButton.Scientific" />
        <Button android:text="e" style="@style/CalcButton.Scientific" />
        <Button android:text="^" style="@style/CalcButton.Scientific" />
        <Button android:text="!" style="@style/CalcButton.Scientific" />
        <Button android:text="inv" style="@style/CalcButton.Scientific" />
        <Button android:text="abs" style="@style/CalcButton.Scientific" />

    </GridLayout>

    <GridLayout
        android:id="@+id/basicPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:columnCount="4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <Button android:text="C" style="@style/CalcButton.Function" />
        <Button android:text="(" style="@style/CalcButton.Function" />
        <Button android:text=")" style="@style/CalcButton.Function" />
        <Button android:text="/" style="@style/CalcButton.Operator" />

        <Button android:text="7" style="@style/CalcButton.Number" />
        <Button android:text="8" style="@style/CalcButton.Number" />
        <Button android:text="9" style="@style/CalcButton.Number" />
        <Button android:text="*" style="@style/CalcButton.Operator" />

        <Button android:text="4" style="@style/CalcButton.Number" />
        <Button android:text="5" style="@style/CalcButton.Number" />
        <Button android:text="6" style="@style/CalcButton.Number" />
        <Button android:text="-" style="@style/CalcButton.Operator" />

        <Button android:text="1" style="@style/CalcButton.Number" />
        <Button android:text="2" style="@style/CalcButton.Number" />
        <Button android:text="3" style="@style/CalcButton.Number" />
        <Button android:text="+" style="@style/CalcButton.Operator" />

        <Button android:text="0" style="@style/CalcButton.Number" />
        <Button android:text="." style="@style/CalcButton.Number" />
        <Button android:text="DEL" style="@style/CalcButton.Function" />
        <Button android:text="=" style="@style/CalcButton.Equals" />

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>